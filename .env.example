# GEMINI_API_KEY_FR: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY_FR="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TELEGRAM_BOT_TOKEN: Optional token to connect the automated agent alerts directly to your Telegram channel.
TELEGRAM_BOT_TOKEN="MY_TELEGRAM_BOT_TOKEN"

# SUPABASE_URL: The API URL of your Supabase project (e.g. https://your-project.supabase.co)
SUPABASE_URL="MY_SUPABASE_URL"

# SUPABASE_ANON_KEY: The public anonymous API key of your Supabase project
SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"

# SUPABASE_SCHEMA: The specific database schema to isolate this app's tables (e.g. "funding_radar" or "public")
SUPABASE_SCHEMA="public"

